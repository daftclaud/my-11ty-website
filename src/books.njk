---
layout: base.njk
locale: en
title: Books
description: A timeline-style shelf of books sourced from my Word Curations.
permalink: /books/
---

<style>
  .books-intro {
    margin: 0 0 24px;
    line-height: 1.7;
  }

  .books-stats {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 22px;
    border: 2px solid var(--clr-border);
    border-radius: 999px;
    padding: 8px 14px;
    background: color-mix(in srgb, var(--clr-main-bg) 88%, var(--clr-nav-bg) 12%);
  }

  .books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: 16px;
  }

  .year-section {
    margin: 28px 0 36px;
    border-top: 2px dashed var(--clr-border-dashed);
    padding-top: 20px;
  }

  .year-header {
    margin-bottom: 14px;
  }

  .year-title-row {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }

  .year-title {
    margin: 0;
    color: var(--clr-heading);
    font-size: 1.4rem;
  }

  .year-stats {
    font-size: 0.82rem;
    border: 1px solid var(--clr-border);
    border-radius: 999px;
    padding: 4px 10px;
    opacity: 0.9;
  }

  .book-cover-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .book-title-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .book-title-link:hover {
    opacity: 0.85;
  }

  .book-card {
    border: 2px solid var(--clr-border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--clr-main-bg);
    box-shadow: 2px 2px 0 color-mix(in srgb, var(--clr-text) 45%, transparent);
  }

  .book-cover-wrap {
    aspect-ratio: 2 / 3;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--clr-main-bg) 70%, var(--clr-nav-bg) 30%), var(--clr-main-bg)),
      repeating-linear-gradient(45deg, rgba(255, 255, 255, 0.12) 0 10px, rgba(0, 0, 0, 0.08) 10px 20px);
    display: grid;
    place-items: center;
    border-bottom: 2px solid var(--clr-border);
    position: relative;
  }

  .book-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: none;
  }

  .book-cover-placeholder {
    font-size: 0.95rem;
    text-align: center;
    padding: 14px;
    opacity: 0.85;
  }

  .book-content {
    padding: 12px;
  }

  .book-title {
    margin: 0 0 8px;
    font-size: 1.05rem;
    line-height: 1.35;
    color: var(--clr-heading);
  }

  .book-author {
    margin: 0 0 10px;
    font-size: 0.92rem;
    opacity: 0.88;
  }

  .book-meta {
    font-size: 0.82rem;
    display: grid;
    gap: 6px;
    opacity: 0.9;
  }

  .book-source {
    margin-top: 10px;
    font-size: 0.78rem;
    opacity: 0.75;
    border-top: 1px dashed var(--clr-border-dashed);
    padding-top: 8px;
    overflow-wrap: anywhere;
  }

  @media (max-width: 600px) {
    .books-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<h1>Books</h1>
<p class="books-intro">
  Here are the books I have read over the years, organized by estimated reading year.
</p>
<div class="books-stats">
  <strong>{{ booksPage.totalBooks }}</strong>
  <span>books tracked</span>
</div>

{% if booksPage.booksByYear.length %}
  {% for yearGroup in booksPage.booksByYear %}
    <section class="year-section" aria-label="Books read in {{ yearGroup.year }}">
      <div class="year-header">
        <div class="year-title-row">
          <h2 class="year-title">{{ yearGroup.year }}</h2>
          <span class="year-stats">{{ yearGroup.totalBooks }} books · {{ yearGroup.totalWords }} curated words</span>
        </div>
      </div>

      <div class="books-grid" aria-label="Books list for {{ yearGroup.year }}">
        {% for book in yearGroup.books %}
          <article class="book-card">
            <div class="book-cover-wrap">
              {% if book.coverPath %}
                <a href="{{ book.infoUrl }}" target="_blank" rel="noopener noreferrer" class="book-cover-link" aria-label="Learn more about {{ book.title }}">
                  <img
                    class="book-cover"
                    src="{{ book.coverPath }}"
                    alt="Cover for {{ book.title }}"
                    loading="lazy"
                    decoding="async"
                    style="display: block;"
                  />
                </a>
              {% else %}
                <div class="book-cover-placeholder">Cover unavailable</div>
              {% endif %}
            </div>
            <div class="book-content">
              <h3 class="book-title">
                {{ book.estimatedOrder }}.
                <a href="{{ book.infoUrl }}" target="_blank" rel="noopener noreferrer" class="book-title-link">{{ book.title }}</a>
              </h3>
              {% if book.author %}
                <p class="book-author">by {{ book.author }}</p>
              {% endif %}
              <div class="book-meta">
                <div>{{ book.wordsCount }} word{% if book.wordsCount != 1 %}s{% endif %} curated from this source</div>
                {% if book.firstSeen %}
                  <div>Reading window: {{ book.firstSeen | formatDate('en-US') }} to {{ book.lastSeen | formatDate('en-US') }}</div>
                {% endif %}
              </div>
              <div class="book-source">Source key: {{ book.source }}</div>
            </div>
          </article>
        {% endfor %}
      </div>
    </section>
  {% endfor %}
{% else %}
  <p>No books were found in Books/Novels yet.</p>
{% endif %}
